# ---------------- SECURITY ----------------
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=False
OTP_BYPASS=True

# ---------------- BASE URL ----------------
BASE_URL=http://localhost:8000

# ---------------- GOOGLE LOGIN ----------------
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=

# ---------------- OPENAI ----------------
OPENAI_API_KEY=

# ---------------- WHATSAPP QR GATEWAY (DEMO) ----------------
# Used to auto-fill the user-side WhatsApp Setup Wizard (QR Login).
# Change these to your actual gateway service values.
WA_GATEWAY_BASE_URL=
WA_GATEWAY_API_KEY=
WA_DEFAULT_COUNTRY_CODE=91
WA_GATEWAY_AUTOSTART=false

# ---------------- ADDONS PLATFORM ----------------
# False ही रखना है (क्योंकि आपके project में addons নেই)
ADDONS_PLATFORM_ENABLED=False

# ---------------- CELERY / REDIS ----------------
# अगर Redis local नहीं है तो इन दोनों को empty भी रख सकते हैं
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# ---------------- EMAIL CONFIG ----------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# ---------------- RENDER / DEPLOY ----------------
RENDER_EXTERNAL_HOSTNAME=

# ---------------- HYBRID DESKTOP + CLOUD SYNC ----------------
# Desktop (offline-first) build (run_desktop.py sets this automatically):
DESKTOP_MODE=False
# Desktop -> Cloud base URL (when internet is available), example:
# CLOUD_API_URL=https://your-cloud-domain.com
CLOUD_API_URL=
# Desktop app version shown in UI/footer (run_desktop.py also sets a default).
DESKTOP_APP_VERSION=1.0.1
# Shared token used by desktop client (Authorization: Token <token>)
# and verified by the cloud endpoint via SYNC_API_TOKEN.
CLOUD_API_TOKEN=
# Cloud server: set this to the same value as CLOUD_API_TOKEN.
SYNC_API_TOKEN=
# Optional: token for desktop EXE update API (if empty, SYNC_API_TOKEN is used).
DESKTOP_UPDATE_TOKEN=

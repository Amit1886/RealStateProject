# Server
PORT=3100
NODE_ENV=production

# API Auth (Bearer token)
GATEWAY_API_KEY=DEMO_WA_GATEWAY_KEY_CHANGE_ME
# Optional (dev only): allow localhost calls when no key is set
# ALLOW_NO_AUTH=true

# Storage
SESSIONS_PATH=./.sessions
TEMPLATES_PATH=./templates.json
AUTO_START_SESSIONS=true
MEDIA_MAX_BYTES=3145728

# Webhook behavior
WEBHOOK_TIMEOUT_MS=8000
WEBHOOK_RETRY_COUNT=2
WEBHOOK_RETRY_DELAY_MS=1000

# WhatsApp Web / Puppeteer
PUPPETEER_HEADLESS=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox
# Optional: use system Chrome if bundled Chromium is blocked
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
